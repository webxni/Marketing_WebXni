# Copy this file to .env and fill in the values

# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# The bot_token value stored in your KV settings:system.discord_bot_secret
# Used to authenticate requests to the WebXni API
DISCORD_BOT_SECRET=

# Your Discord user ID (for DM support)
DISCORD_OWNER_ID=1468394932837552248

# Channel the bot listens to (messages here → AI agent)
DISCORD_CHANNEL_ID=1242943323828916234

# WebXni API base URL
API_BASE_URL=https://marketing.webxni.com
