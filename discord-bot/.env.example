# Copy this file to .env and fill in the values

# Bot token from Discord Developer Portal → Bot → Reset Token
DISCORD_BOT_TOKEN=

# The bot_token value stored in your KV settings:system.discord_bot_secret
# Used to authenticate requests to the WebXni API
DISCORD_BOT_SECRET=

# Your Discord user ID (for DM support)
DISCORD_OWNER_ID=1468394932837552248

# Channel the bot listens to (messages here → AI agent)
DISCORD_CHANNEL_ID=1242943323828916234

# WebXni API base URL
API_BASE_URL=https://marketing.webxni.com

# AI Agency OS controls
AGENCY_ENABLED=true
AGENCY_NOTIFY_CHANNEL_ID=
AGENCY_MAX_CONCURRENT_JOBS=1
AGENCY_SYSTEM_REVIEW_ENABLED=true
AGENCY_SECURITY_ENABLED=true
AGENCY_WEEKLY_SOCIAL_ENABLED=true
AGENCY_WEEKLY_BLOG_ENABLED=true
AGENCY_DAILY_RESEARCH_CLIENT_LIMIT=2
AGENCY_DAILY_BLOG_LIMIT=1
AGENCY_DAILY_STRATEGY_CLIENT_LIMIT=3
AGENCY_REDACT_SECRETS=true
AGENCY_LOG_RETENTION_DAYS=30

# --- Safety gates for run-approved-agency-job.mjs ---
# AGENCY_EXECUTE_AI=0 means all agent runs produce dry-run summaries (no real AI calls).
# Set AGENCY_EXECUTE_AI=1 only when you are ready to spend AI budget on agency runs.
AGENCY_EXECUTE_AI=0

# AGENCY_ALLOW_DRAFT_POSTS=0 means social/blog agent runs never create new draft posts.
# Set AGENCY_ALLOW_DRAFT_POSTS=1 only when strategy and research are in place.
AGENCY_ALLOW_DRAFT_POSTS=0

# Which terminal CLI to use when AGENCY_EXECUTE_AI=1.
# Options: auto (tries codex → gemini → claude), claude, gemini, codex
# Research agent defaults to gemini to use the free CLI quota.
AGENCY_TERMINAL_AGENT=auto
AGENCY_RESEARCH_BACKEND=gemini

# Cloudflare Worker env var — enables cron-triggered agency scheduler.
# Set to true in wrangler.toml or KV settings:system.agency_scheduler_enabled.
# Defaults to false (off) until you are ready to run scheduled agent jobs daily.
AGENCY_SCHEDULER_ENABLED=false

# Terminal AI budget/model hints used by agent runners.
CLAUDE_CODE_MODEL=sonnet
CLAUDE_STRATEGY_MODEL=sonnet
CLAUDE_REVIEW_MODEL=sonnet
CLAUDE_BLOG_MODEL=sonnet
CLAUDE_MAX_TURNS=1
CLAUDE_MAX_BUDGET_USD=0.50
GEMINI_RESEARCH_MODEL=
GEMINI_DAILY_CLIENT_LIMIT=2
GEMINI_RESEARCH_MAX_QUERIES_PER_CLIENT=5
ANTHROPIC_API_KEY=

# OpenAI — used as Agency Orchestrator base and as a fallback for all agents
# when preferred CLI backend (codex/claude/gemini) is unavailable.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BLOG_MODEL=gpt-4o

# --- Heartbeat daemon (scripts/run-agency-heartbeat-daemon.mjs) ---
# How often the daemon checks for stale agents (minutes).
HEARTBEAT_INTERVAL_MINUTES=30
