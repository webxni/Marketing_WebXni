{
  "name": "marketing-webxni-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 execute webxni-db --file=../db/schema.sql",
    "db:migrate:local": "wrangler d1 execute webxni-db --local --file=../db/schema.sql",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "zod": "^3.23.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240923.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.5.0",
    "wrangler": "^3.80.0"
  }
}
